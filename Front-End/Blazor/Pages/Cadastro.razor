@page "/cadastro"
<PageTitle>Cadastro</PageTitle>
@layout NoLayout
@using Blazor.DTOs.Usuario
@using Services
@inject AuthService Auth

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Criar Conta</h4>
                </div>
                <div class="card-body p-4">
                    <EditForm Model="dto" OnValidSubmit="FazerCadastro">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Nome Completo</label>
                            <InputText @bind-Value="dto.Nome" class="form-control" placeholder="Digite seu nome" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <InputText @bind-Value="dto.Email" class="form-control" placeholder="exemplo@email.com" />
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">Senha</label>
                                <InputText type="password" @bind-Value="dto.Senha" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Confirmar Senha</label>
                                <InputText type="password" @bind-Value="dto.confirmSenha" class="form-control" />
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Entrar
                            </button>
                        </div>
                        <div class="d-grid m-3">
                            <NavLink href="/" class="btn btn-primary btn-lg">
                                Voltar
                            </NavLink>
                        </div>

                        <ValidationSummary class="mt-3 text-danger small" />
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    public CadastroRequestDto dto = new();


    public async Task FazerCadastro()
    {
        await Auth.Cadastro(dto);
    }
}
