@using Blazor.Application.DTOs.Carrinho

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-3">Produto</th>
                    <th class="text-center">Qtd</th>
                    <th class="text-end">Unitário</th>
                    <th class="text-end pe-3">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @if (carrinho?.Itens != null)
                {
                    @foreach (var item in carrinho.Itens)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="fw-bold text-dark">@item.NomeProduto</div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@item.Quantidade</span>
                            </td>
                            <td class="text-end text-muted">@item.PrecoUnitario.ToString("C")</td>
                            <td class="text-end fw-bold">@item.SubTotal.ToString("C")</td>
                            <td class="text-center pe-3">
                                <button class="btn btn-outline-danger btn-sm border-0"
                                        @onclick="() => RemoverItem(item.ProdutoId)"
                                        title="Remover item">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter]
    public CarrinhoResponseDto carrinho { get; set; } = new();

    // Adicione um EventCallback para notificar a página pai que um item deve ser removido
    [Parameter]
    public EventCallback<int> OnRemoverItem { get; set; }

    private async Task RemoverItem(int produtoId)
    {
        await OnRemoverItem.InvokeAsync(produtoId);
    }
}