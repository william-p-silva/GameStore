@using Blazor.Application.DTOs.Produto
@using Blazor.Application.DTOs.Carrinho
@using Blazor.Application.Services
@inject CarrinhoService CarSvc
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="col">
    <div class="card h-100 shadow-sm border-0 transition-hover">
        <div class="position-absolute top-0 end-0 m-2">
            <span class="badge bg-light text-dark shadow-sm">@produto.CategoriaNome</span>
        </div>

        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
            <i class="bi bi-box-seam display-4 text-muted"></i>
        </div>

        <div class="card-body d-flex flex-column">
            <h5 class="card-title fw-bold text-dark mb-1">@produto.Nome</h5>
            <p class="card-text text-muted small flex-grow-1">
                @(produto.Descricao.Length > 80 ? produto.Descricao.Substring(0, 80) + "..." : produto.Descricao)
            </p>

            <div class="mt-auto">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fs-4 fw-bold text-primary">@produto.Preco.ToString("C")</span>
                    <span class="small @(produto.Estoque > 0 ? "text-success" : "text-danger")">
                        @(produto.Estoque > 0 ? $"{produto.Estoque} em estoque" : "Esgotado")
                    </span>
                </div>

                <button class="btn btn-outline-primary w-100 d-flex align-items-center justify-content-center gap-2"
                        disabled="@(!produto.Ativo || produto.Estoque <= 0)" @onclick="(
                        () => AdicionarAocarrinho(new AdicionarProdutoRequestDto{
                        ProdutoID = produto.Id,
                        }))">
                    <i class="bi bi-cart-plus"></i> Detalhes
                </button>
            </div>
        </div>
    </div>
</div>




@if (exibirModal && carrinho != null)
{
    <div class="modal-backdrop" @onclick="() => exibirModal = false">
        @* Paramos a propagação do clique para o modal não fechar ao clicar no conteúdo *@
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="text-center">
                <i class="bi bi-check-circle-fill text-success display-4"></i>
                <h3 class="mt-2">Item Adicionado!</h3>
            </div>
            <hr />
            <p class="text-muted">Você tem <strong>@carrinho.TotalItens</strong> itens no carrinho.</p>
            
            <div style="max-height: 200px; overflow-y: auto;">
                <ul class="list-group list-group-flush">
                    @foreach (var item in carrinho.Itens)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@item.NomeProduto <small class="text-muted">x @item.Quantidade</small></span>
                            <span class="fw-bold">@item.SubTotal.ToString("C")</span>
                        </li>
                    }
                </ul>
            </div>

            <div class="alert alert-light border mt-3 d-flex justify-content-between">
                <strong>Total do Carrinho:</strong>
                <span class="text-primary fw-bold">@carrinho.TotalCarrinho.ToString("C")</span>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                <button class="btn btn-outline-secondary me-md-2" @onclick="() => exibirModal = false">Voltar</button>
                <button class="btn btn-primary" @onclick="IrParaCarrinho">Ver Carrinho</button>
            </div>
        </div>
    </div>
}


@code {
    [Parameter]
    public ProdutoResponseDto produto { get; set; } = new();

    private CarrinhoResponseDto? carrinho;
    private bool exibirModal = false;

    public async Task AdicionarAocarrinho(AdicionarProdutoRequestDto adicionar)
    {
        try
        {
            carrinho = await CarSvc.AdicionarProdutoAoCarrinho(adicionar);

            exibirModal = true;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", new {
        title = "Erro!",
        text = "Erro ao Adicionar ao Carrinho",
        icon = "error",
        confirmButtonText = "Entendido"
    });
            Console.WriteLine(ex.Message);
        }
    }

    private void IrParaCarrinho()
    {
        // Navega para a tela de checkout
        NavigationManager.NavigateTo("/cliente/carrinho");
    }
}
